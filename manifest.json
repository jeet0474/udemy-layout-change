{
  "manifest_version": 3,
  "name": "Udemy Video Resizer",
  "description": "Drag to resize Udemy video area vertically. Expands lecture view and saves layout automatically.",
  "version": "1.1.0",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": ["storage"],

  "content_scripts": [
    {
      "matches": ["*://*.udemy.com/*"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ],

  "action": {
    "default_title": "Udemy Video Resizer"
  }
}